FROM python:3.12-slim
WORKDIR /app

COPY profiler-service/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY profiler-service/app.py ./profiler_app.py
COPY discovery/config/seed_glossary.yaml ./seed_glossary.yaml

ENV GLOSSARY_PATH=/app/seed_glossary.yaml
ENV PYTHONPATH=/app

EXPOSE 8080
CMD ["uvicorn", "profiler_app:app", "--host", "0.0.0.0", "--port", "8080"]
