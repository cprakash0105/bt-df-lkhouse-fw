# Stage 1: Build React frontend
FROM node:20-alpine AS frontend
WORKDIR /app/web
COPY discovery/web/package.json ./
RUN npm install
COPY discovery/web/ ./
RUN npm run build

# Stage 2: Python API + serve static
FROM python:3.12-slim
WORKDIR /app

# Install Python deps (minimal for API)
COPY discovery/requirements-web.txt ./
RUN pip install --no-cache-dir -r requirements-web.txt

# Copy engine, config, API
COPY logger.py ./
COPY discovery/__init__.py ./discovery/
COPY discovery/engine/ ./discovery/engine/
COPY discovery/config/ ./discovery/config/
COPY discovery/api/ ./discovery/api/

# Copy built frontend into static
COPY --from=frontend /app/web/dist ./static/

ENV PYTHONPATH=/app

EXPOSE 8080
CMD ["uvicorn", "discovery.api.main:app", "--host", "0.0.0.0", "--port", "8080"]
