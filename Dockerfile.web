# Stage 1: Build React frontend
FROM node:20-alpine AS frontend
WORKDIR /app/web
COPY discovery/web/package.json ./
RUN npm install
COPY discovery/web/ ./
RUN npm run build

# Stage 2: Python API + serve static
FROM python:3.12-slim
WORKDIR /app

# Install Python deps
COPY discovery/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt fastapi uvicorn

# Copy engine + API
COPY discovery/ ./discovery/

# Copy built frontend into static
COPY --from=frontend /app/web/dist ./static/

# Serve static from FastAPI
ENV PYTHONPATH=/app

EXPOSE 8080
CMD ["uvicorn", "discovery.api.main:app", "--host", "0.0.0.0", "--port", "8080"]
