FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY discovery/requirements.txt .
RUN pip install --no-cache-dir pyyaml numpy chainlit fastapi uvicorn aiofiles

# Copy discovery module
COPY discovery/ /app/discovery/

# Chainlit needs to run from a directory with the app
WORKDIR /app

EXPOSE 8000

CMD ["chainlit", "run", "discovery/ui/app.py", "--port", "8000", "--host", "0.0.0.0"]
