        <mxCell id="det-never" value="LLM NEVER DOES (Execution)&#xa;&#xa;✗ Write to GCS&#xa;✗ Create/alter BQ tables&#xa;✗ Submit Dataproc jobs&#xa;✗ Modify Iceberg schemas&#xa;✗ Write to Dataplex&#xa;✗ Set Policy Tags&#xa;✗ Push configs" style="rounded=1;whiteSpace=wrap;fillColor=#283593;strokeColor=#5c6bc0;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=10;" vertex="1" parent="1">
