        <mxCell id="llm-does" value="WHAT LLM DOES (Reasoning)&#xa;&#xa;✓ Parse natural language → JSON&#xa;✓ Generate BigQuery SQL&#xa;✓ Validate/correct suggestions&#xa;✓ Generate business DQ from stats&#xa;✓ Infer SCD type from intent&#xa;✓ Classify business application" style="rounded=1;whiteSpace=wrap;fillColor=#ad1457;strokeColor=#f06292;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="460" y="135" width="300" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="llm-props" value="PROPERTIES&#xa;&#xa;• Stateless (no memory)&#xa;• Isolated (no infra access)&#xa;• Replaceable (any OpenAI API)&#xa;• Self-hosted (no data leaves)" style="rounded=1;whiteSpace=wrap;fillColor=#ad1457;strokeColor=#f06292;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="460" y="280" width="300" height="100" as="geometry"/>
