          <mxGeometry x="40" y="120" width="200" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="bde-custid" value="BDE: Customer ID&#xa;&#xa;dq_rules:&#xa;  not_null: true&#xa;  unique: true&#xa;&#xa;is_key_candidate: true" style="rounded=1;whiteSpace=wrap;fillColor=#e65100;strokeColor=#ff9800;fontColor=#ffffff;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="270" y="120" width="200" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="bde-pan" value="BDE: PAN Number&#xa;&#xa;dq_rules:&#xa;  format: pan&#xa;&#xa;classification: PII&#xa;is_pii: true" style="rounded=1;whiteSpace=wrap;fillColor=#e65100;strokeColor=#ff9800;fontColor=#ffffff;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="120" width="200" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="bde-csat" value="BDE: CSAT Score&#xa;&#xa;dq_rules:&#xa;  range: [1, 5]" style="rounded=1;whiteSpace=wrap;fillColor=#e65100;strokeColor=#ff9800;fontColor=#ffffff;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="120" width="200" height="120" as="geometry"/>
        </mxCell>
        <!-- Arrow down -->
        <mxCell id="inherit-label" value="INHERITS DOWN (automatic)" style="text;html=1;align=center;fontSize=11;fontStyle=1;fontColor=#66bb6a;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="270" width="250" height="30" as="geometry"/>
        </mxCell>
        <!-- Table Level -->
        <mxCell id="table-label" value="TABLE CONFIG LEVEL (auto-generated)" style="text;html=1;align=center;fontSize=12;fontStyle=1;fontColor=#4fc3f7;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="350" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="table1" value="cibil_bureau_feed.yaml&#xa;&#xa;cibil_score:&#xa;  → not_null ✓ (from Credit Score)&#xa;  → range [300,900] ✓ (from Credit Score)&#xa;&#xa;customer_id:&#xa;  → not_null ✓ (from Customer ID)&#xa;  → unique ✓ (is PK here)&#xa;&#xa;pan_number:&#xa;  → format: pan ✓ (from PAN Number)" style="rounded=1;whiteSpace=wrap;fillColor=#1565c0;strokeColor=#64b5f6;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=10;" vertex="1" parent="1">
