        </mxCell>
        <mxCell id="table2" value="loan_repayment.yaml&#xa;&#xa;customer_id:&#xa;  → not_null ✓ (from Customer ID)&#xa;  → unique ✗ (NOT PK here — FK only)&#xa;&#xa;Smart: unique only on actual PK" style="rounded=1;whiteSpace=wrap;fillColor=#1565c0;strokeColor=#64b5f6;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="360" width="250" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="table3" value="customer_complaints.yaml&#xa;&#xa;csat_score:&#xa;  → range [1,5] ✓ (from CSAT Score)&#xa;  → NOT range [300,900]&#xa;    (correct BDE matched!)&#xa;&#xa;customer_id:&#xa;  → not_null ✓&#xa;  → unique ✗ (FK)" style="rounded=1;whiteSpace=wrap;fillColor=#1565c0;strokeColor=#64b5f6;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="360" width="250" height="160" as="geometry"/>
        </mxCell>
        <!-- Arrows from BDEs to tables -->
        <mxCell id="i1" style="rounded=1;strokeColor=#ff9800;strokeWidth=1;dashed=1;exitX=0.5;exitY=1;entryX=0.3;entryY=0;" edge="1" parent="1" source="bde-credit" target="table1">
