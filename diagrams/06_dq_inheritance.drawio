        <mxCell id="i3" style="rounded=1;strokeColor=#ff9800;strokeWidth=1;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="bde-csat" target="table3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Summary -->
        <mxCell id="summary" value="Result: 4 BDEs → DQ applied to ALL tables automatically.&#xa;Steward defines rules ONCE at business level. Framework handles the rest." style="rounded=1;whiteSpace=wrap;fillColor=#1b5e20;strokeColor=#66bb6a;fontColor=#ffffff;fontSize=10;align=center;" vertex="1" parent="1">
