<mxfile host="app.diagrams.net" modified="2026-06-30T00:00:00.000Z" agent="draw.io" version="21.0.0">
  <diagram name="End-to-End Onboarding" id="e2e-flow">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="End-to-End Onboarding Flow" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="400" height="40" as="geometry"/>
        </mxCell>
        <!-- Human steps label -->
        <mxCell id="human-label" value="HUMAN (5 min)" style="text;html=1;align=center;fontSize=12;fontStyle=1;fontColor=#42a5f5;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="100" y="70" width="200" height="30" as="geometry"/>
        </mxCell>
        <!-- Step 1 -->
        <mxCell id="s1" value="1. Steward speaks to SD&#xa;&#xa;&quot;I have a new customer complaints&#xa;dataset with complaint_id, customer_id,&#xa;channel, priority, status, csat_score&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#1a237e;strokeColor=#42a5f5;fontColor=#ffffff;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="300" height="100" as="geometry"/>
        </mxCell>
        <!-- Step 2 -->
        <mxCell id="s2" value="2. SD auto-profiles + discovers&#xa;&#xa;• Fetches landing data from GCS&#xa;• Profiles: types, cardinality, PII&#xa;• Fingerprints vs 14 reference sets&#xa;• Matches to BDEs (composite score)&#xa;• Suggests DQ, PK, BA, domain" style="rounded=1;whiteSpace=wrap;fillColor=#4a148c;strokeColor=#ab47bc;fontColor=#ffffff;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="240" width="300" height="130" as="geometry"/>
        </mxCell>
        <!-- Step 3 -->
        <mxCell id="s3" value="3. Steward reviews + corrects&#xa;&#xa;• Sees field table with confidence scores&#xa;• Signal breakdown (keyword/pattern/fp/stat)&#xa;• Clicks corrections if needed&#xa;• Types &quot;approve all&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#1a237e;strokeColor=#42a5f5;fontColor=#ffffff;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="300" height="110" as="geometry"/>
        </mxCell>
        <!-- Automated steps label -->
        <mxCell id="auto-label" value="AUTOMATED (3 min)" style="text;html=1;align=center;fontSize=12;fontStyle=1;fontColor=#66bb6a;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="550" y="70" width="200" height="30" as="geometry"/>
        </mxCell>
        <!-- Step 4 -->
        <mxCell id="s4" value="4. SD Approval Handler&#xa;&#xa;• Creates BDEs in Dataplex Glossary&#xa;• Registers dataset in Catalog&#xa;• Creates EntryLinks (BA→BDE)&#xa;• Generates data contract (v1.0.0)&#xa;• Pushes pipeline YAML to GCS&#xa;• Persists profile for audit" style="rounded=1;whiteSpace=wrap;fillColor=#1b5e20;strokeColor=#66bb6a;fontColor=#ffffff;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="110" width="280" height="140" as="geometry"/>
        </mxCell>
        <!-- Step 5 -->
        <mxCell id="s5" value="5. Cloud Function triggers&#xa;&#xa;GCS event: config YAML landed&#xa;&#xa;→ Submit ingest job (Dataproc)&#xa;→ Submit curate job (DQ + dedup)&#xa;→ Create BQ external table&#xa;→ Run consumption SQL&#xa;→ Apply Policy Tags (PII)&#xa;→ Log to pipeline_monitor" style="rounded=1;whiteSpace=wrap;fillColor=#e65100;strokeColor=#ff9800;fontColor=#ffffff;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="280" width="280" height="170" as="geometry"/>
        </mxCell>
        <!-- Step 6 -->
        <mxCell id="s6" value="6. DATA PRODUCT READY&#xa;&#xa;• Queryable in BigQuery&#xa;• PII columns secured&#xa;• DQ validated (inherited from BDEs)&#xa;• Schema governed&#xa;• Contract enforceable&#xa;• Audit trail in pipeline_monitor" style="rounded=1;whiteSpace=wrap;fillColor=#1b5e20;strokeColor=#a5d6a7;fontColor=#ffffff;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="480" width="280" height="130" as="geometry"/>
        </mxCell>
        <!-- Arrows -->
        <mxCell id="a1" style="rounded=1;strokeColor=#42a5f5;strokeWidth=2;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" style="rounded=1;strokeColor=#ab47bc;strokeWidth=2;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" style="rounded=1;strokeColor=#42a5f5;strokeWidth=2;" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4" style="rounded=1;strokeColor=#66bb6a;strokeWidth=2;" edge="1" parent="1" source="s4" target="s5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a5" style="rounded=1;strokeColor=#ff9800;strokeWidth=2;" edge="1" parent="1" source="s5" target="s6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Time annotations -->
        <mxCell id="time1" value="~5 min total" style="text;html=1;align=center;fontSize=10;fontColor=#42a5f5;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="10" y="300" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="time2" value="~3 min total" style="text;html=1;align=center;fontSize=10;fontColor=#66bb6a;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="800" y="350" width="80" height="20" as="geometry"/>
        </mxCell>
        <!-- DQ Inheritance callout -->
        <mxCell id="dq-callout" value="DQ INHERITANCE&#xa;&#xa;BDE &quot;Credit Score&quot;:&#xa;  range: [300, 900]&#xa;&#xa;→ Applied to ALL tables&#xa;  using that BDE" style="rounded=1;whiteSpace=wrap;fillColor=#b71c1c;strokeColor=#ef5350;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="110" width="160" height="120" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
