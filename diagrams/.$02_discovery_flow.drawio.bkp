        </mxCell>
        <!-- Step 4: Fingerprint -->
        <mxCell id="step4" value="STEP 4: FINGERPRINT&#xa;&#xa;Values vs ALL ref sets:&#xa;&#xa;status values:&#xa;[open, closed, resolved]&#xa;  vs order_statuses → 0%&#xa;  vs complaint_statuses → 100% ✓&#xa;  vs payment_statuses → 0%&#xa;&#xa;→ Override wrong BDE match" style="rounded=1;whiteSpace=wrap;fillColor=#e65100;strokeColor=#ff9800;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
