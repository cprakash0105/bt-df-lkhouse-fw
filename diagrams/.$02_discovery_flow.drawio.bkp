        <!-- Step 1-3: Analyze -->
        <mxCell id="step13" value="STEPS 1–3: ANALYZE&#xa;&#xa;Layer 1: KG Synonym Match&#xa;  → cibil_score → Credit Score&#xa;&#xa;Layer 2: Rules Engine&#xa;  → *_id → Identifier&#xa;  → *email* → PII&#xa;&#xa;Layer 3: Embeddings&#xa;  → Semantic similarity" style="rounded=1;whiteSpace=wrap;fillColor=#1565c0;strokeColor=#64b5f6;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
