# Semantic Discovery - Environment Variables
# Copy this to .env and fill in your keys

# LLM API (Perplexity - OpenAI compatible)
LLM_API_KEY=your_perplexity_api_key_here
LLM_BASE_URL=https://api.perplexity.ai
LLM_MODEL=sonar

# GCP
GCP_PROJECT_ID=bt-df-lkhouse
GCP_REGION=europe-west2
CONFIG_BUCKET=bt-df-lkhouse-lakehouse
