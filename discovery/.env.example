# Semantic Discovery - Environment Variables
# Copy this to .env and fill in your keys

# LLM — AWS Bedrock Mantle (default)
LLM_PROVIDER=bedrock
LLM_MODEL=mistral.ministral-3-8b-instruct
AWS_REGION=eu-north-1
# Token generated automatically via aws_bedrock_token_generator

# Alternative: Self-hosted Ollama (set LLM_PROVIDER=openai)
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://13.60.243.121:11434/v1
# LLM_MODEL=gemma2
# LLM_API_KEY=not-needed

# GCP
GCP_PROJECT_ID=bt-df-lkhouse
GCP_REGION=europe-west2
CONFIG_BUCKET=eastside-lakehouse
